# Server Configuration
LOG_LEVEL=INFO

# OpenAPI Key (if using OpenAI models)
OPENAI_API_KEY=your_openai_api_key_here

# HuggingFace Token (if using gated models or inference API)
HUGGINGFACEHUB_API_TOKEN=your_huggingface_token_here

# Vector Store preference (faiss or chroma)
VECTOR_STORE_TYPE=faiss
